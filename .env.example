# ─── Core Application ─────────────────────────────────────────────────────────
NODE_ENV="development"
DATABASE_PATH="./prisma/data.db"
DATABASE_URL="file:./data.db?connection_limit=1"
CACHE_DATABASE_PATH="./other/cache.db"
SESSION_SECRET="change-me-to-a-random-string"
HONEYPOT_SECRET="change-me-to-a-random-string"
INTERNAL_COMMAND_TOKEN="change-me-to-a-random-string"

# ─── Object Storage (S3-compatible, e.g. Tigris on Fly.io) ───────────────────
# Required for photo uploads and school asset storage
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="auto"
AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
BUCKET_NAME="your-bucket-name"

# ─── FACTS SIS API ───────────────────────────────────────────────────────────
# Required. Get these from the FACTS Developer Portal.
# Can also be configured in the setup wizard.
FACTS_SUBSCRIPTION_KEY="your-subscription-key"
FACTS_API_KEY="your-api-key"
FACTS_BASE_URL="https://api.factsmgt.com"

# ─── Google Workspace (Optional) ─────────────────────────────────────────────
# Enable Google OAuth login + photo sync + Gmail signatures
# Set via setup wizard, or manually here.
# GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"
# GOOGLE_REDIRECT_URI="https://your-app.fly.dev/auth/google/callback"
# GOOGLE_SERVICE_ACCOUNT_EMAIL="sa@project.iam.gserviceaccount.com"
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
# GOOGLE_ADMIN_EMAIL="admin@yourschool.org"

# ─── School Branding (Optional env overrides) ────────────────────────────────
# These are typically set via the setup wizard and stored in the database.
# Env vars here serve as fallbacks if the DB values are not set.
# SCHOOL_NAME="Your School Name"
# SCHOOL_EMAIL_DOMAIN="yourschool.org"
# SCHOOL_LOGO_URL="https://storage.example.com/logo.png"
# SCHOOL_PRIMARY_COLOR="#1B2A4A"
# SCHOOL_SECONDARY_COLOR="#8B1A2B"

# ─── Optional Services ───────────────────────────────────────────────────────
# SENTRY_DSN="your-sentry-dsn"
# RESEND_API_KEY="re_xxxx"
# ALLOW_INDEXING="true"

# ─── GitHub OAuth (Optional — usually not needed for school deployments) ─────
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"
# GITHUB_TOKEN="your-github-token"
# GITHUB_REDIRECT_URI="https://your-app.fly.dev/auth/github/callback"
